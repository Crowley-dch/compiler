fn sum(n int) -> int {
    int result = 0;
    int i = 0;

    while (i <= n) {
        result = result + i;
        i = i + 1;
    }

    return result;
}

fn product(n int) -> int {
    int result = 1;
    int i = 1;

    for (i = 1; i <= n; i = i + 1) {
        result = result * i;
    }

    return result;
}

fn power(base int, exp int) -> int {
    int result = 1;
    int i = 0;

    for (i = 0; i < exp; i = i + 1) {
        result = result * base;
    }

    return result;
}

fn main() -> void {
    int s = sum(10);
    int p = product(5);
    int pow = power(2, 8);

    return s + p + pow;
}